{
  "name": "@mp-consulting/homebridge-ewelink",
  "displayName": "eWeLink",
  "version": "1.0.31",
  "type": "module",
  "description": "Homebridge plugin to integrate eWeLink devices into HomeKit",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "watch": "npm run build && npm link && nodemon",
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run build",
    "prepare": "npm run build",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org --access=public",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com --access=public",
    "publish:all": "npm run publish:npm && npm run publish:github",
    "detect-api-changes": "npx tsx scripts/detect-api-changes.ts",
    "detect-api-changes:save": "npx tsx scripts/detect-api-changes.ts --save"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "homekit",
    "ewelink",
    "sonoff",
    "zigbee",
    "rf",
    "hoobs",
    "smart-home"
  ],
  "author": "mp-consulting",
  "license": "MIT",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "homepage": "https://github.com/mp-consulting/homebridge-ewelink#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-ewelink.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-ewelink/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.18.0 || ^22.9.0 || ^24",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "axios": "^1.14.0",
    "bonjour-service": "^1.3.0",
    "crypto-js": "^4.2.0",
    "dns-packet": "^5.6.1",
    "fakegato-history": "^0.6.7",
    "node-persist": "^4.0.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/node-persist": "^3.1.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.21.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}
